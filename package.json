{
  "name": "cime-sdk",
  "version": "1.1.1",
  "description": "방송 플랫폼 씨미의 비공식 SDK입니다. 공식 API를 기반으로 합니다.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cime",
    "sdk",
    "typescript"
  ],
  "author": "whitespaca",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/whitespaca/cime-sdk"
  },
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.0",
    "axios-retry": "^4.5.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
